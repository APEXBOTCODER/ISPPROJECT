// Infinity Sports Park — data model (SQLite for dev; swap datasource to postgresql for prod)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  phone         String?
  role          String    @default("CUSTOMER") // CUSTOMER | STAFF | ADMIN
  active        Boolean   @default(true) // deactivated users can't log in or book
  // When set, the user must re-sign the waiver: any signature dated before this
  // no longer counts, so they are forced to sign again before their next booking.
  waiverResignRequiredAt DateTime?
  emailVerified DateTime?
  phoneVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings          Booking[]
  reservations      Reservation[]
  waiverSignatures  WaiverSignature[]
  verificationCodes VerificationCode[]
  refundsReceived   RefundRecord[]     @relation("UserRefunds")
  refundsIssued     RefundRecord[]     @relation("StaffRefunds")
}

// Audit trail for every refund (and the source of truth for a user's total
// refunded amount, which caps custom refunds). Append-only.
model RefundRecord {
  id            String   @id @default(cuid())
  userId        String // the customer refunded
  staffId       String // who issued it (the customer themselves for self-cancels)
  reservationId String?
  bookingId     String?
  scope         String // SEGMENT | RESERVATION | CUSTOM
  amountCents   Int
  cancelled     Boolean  @default(false) // did it also cancel the booking + free slots
  reason        String
  paymentRef    String?
  createdAt     DateTime @default(now())

  user  User @relation("UserRefunds", fields: [userId], references: [id])
  staff User @relation("StaffRefunds", fields: [staffId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// Groups one or more Booking rows paid/managed together — a multi-day booking
// (kind=BOOKING, one payment across all day-segments) or a multi-day
// maintenance block (kind=BLOCK). A single-day booking is just a reservation
// with one Booking.
model Reservation {
  id            String   @id @default(cuid())
  userId        String
  kind          String   @default("BOOKING") // BOOKING | BLOCK
  label         String? // entity/org name (bookings) or reason (blocks)
  totalCents    Int      @default(0)
  refundedCents Int      @default(0)
  paymentRef    String?
  status        String   @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  bookings Booking[]

  @@index([userId])
}

// Short-lived 6-digit codes for email/phone ownership verification.
// Codes are stored hashed; max 5 attempts; one active code per channel.
model VerificationCode {
  id         String    @id @default(cuid())
  userId     String
  channel    String // EMAIL | PHONE
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
}

model Resource {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  sport       String // CRICKET | SOCCER | NETS | TRAINING
  description String
  openHour    Int     @default(8) // park-local time (America/Chicago)
  closeHour   Int     @default(22)
  baseRate    Int // cents per hour, off-peak
  peakRate    Int // cents per hour, weekday evenings + weekends
  active      Boolean @default(true)
  sortOrder   Int     @default(0)

  bookings Booking[]
}

// A booking spans one or more contiguous hourly slots on a single resource/date.
// Maintenance blocks are bookings with status BLOCKED (created by staff), so they
// occupy slots through the same unique constraint as customer bookings.
model Booking {
  id            String   @id @default(cuid())
  userId        String
  reservationId String? // groups multi-day bookings / blocks (null for legacy rows)
  resourceId    String
  date          String // YYYY-MM-DD, park-local
  startHour     Int
  endHour       Int // exclusive
  status        String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED | BLOCKED
  totalCents    Int      @default(0)
  refundedCents Int      @default(0)
  noShow        Boolean  @default(false) // staff-flagged no-show (past confirmed bookings)
  paymentRef    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  reservation Reservation?  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  resource    Resource      @relation(fields: [resourceId], references: [id])
  slots       BookingSlot[]

  @@index([userId, date])
  @@index([resourceId, date])
  @@index([reservationId])
}

// One row per occupied hour. The unique constraint is the double-booking guard:
// two concurrent checkouts for the same slot cannot both insert.
model BookingSlot {
  id         String @id @default(cuid())
  bookingId  String
  resourceId String
  slotKey    String // "YYYY-MM-DD:HH" park-local

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([resourceId, slotKey])
}

// Admin-managed events shown on /tournaments (replaces the former static array).
model Tournament {
  id          String   @id @default(cuid())
  name        String
  timing      String // e.g. "Summer 2026 · opening weekend"
  description String
  ctaLabel    String   @default("Register interest")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Uploaded images, stored in the database so they persist identically in dev
// (SQLite BLOB) and production (Postgres bytea) with no external object store.
// Keyed by a fixed registry slot (see src/lib/media.ts).
model MediaAsset {
  slot      String   @id
  mimeType  String
  data      Bytes
  alt       String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Editable page copy / toggles (key-value). Defaults live in src/lib/settings.ts;
// a row here overrides the default.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model WaiverDocument {
  id        String   @id @default(cuid())
  version   Int      @unique
  title     String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  signatures WaiverSignature[]
}

// Append-only: signatures are never updated or deleted (legal audit trail).
model WaiverSignature {
  id               String   @id @default(cuid())
  userId           String
  documentId       String
  version          Int
  signedName       String
  participantName  String // signer, or minor's name for guardian waivers
  minorDob         String?
  guardianRelation String?
  ipAddress        String
  userAgent        String?
  initials         String? // JSON array of initials entered at each [[initial]] marker, in order
  // Registration data collected with the waiver (Smartwaiver-equivalent):
  participantType  String? // "ADULT" | "MINOR"
  participantDob   String? // participant's date of birth (the minor's, for guardian waivers)
  phone            String?
  address          String?
  emergencyName    String?
  emergencyPhone   String?
  allergies        String?
  medical          String?
  mediaRelease     Boolean  @default(true) // false = participant opted OUT of the photo/media release
  consentEsign     Boolean  @default(false) // ESIGN/UETA electronic-signature consent
  pdfSha256        String? // SHA-256 of the sealed PDF (tamper-evidence)
  emailedAt        DateTime?
  signedAt         DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id])
  document WaiverDocument @relation(fields: [documentId], references: [id])
  pdf      WaiverPdf?

  @@index([userId, version])
}

// The sealed PDF rendered at signing time — the immutable evidentiary artifact.
// Bytes live in their own table so signature queries don't load them.
model WaiverPdf {
  signatureId String   @id
  data        Bytes
  createdAt   DateTime @default(now())

  signature WaiverSignature @relation(fields: [signatureId], references: [id], onDelete: Cascade)
}
