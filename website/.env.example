# ─────────────────────────────────────────────────────────────────────────────
# Infinity Sports Park — environment variables
# Copy to `.env` for local dev, or set these in your host's dashboard for prod.
# NEVER commit a real .env — only this .example file is tracked.
# Full walkthrough: DEPLOYMENT.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite, default):
DATABASE_URL="file:./prisma/dev.db"
# Production, persistent-disk host (Railway/Render/Fly) — point at the volume:
#   DATABASE_URL="file:/data/prod.db"
# Production, Postgres (Neon/Supabase/RDS) — see DEPLOYMENT.md §Option B:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# REQUIRED in production. Generate with:  npx auth secret
AUTH_SECRET=""
# true on any host that terminates TLS at a proxy (Railway/Render/Fly/Lightsail).
# Not needed on Vercel.
AUTH_TRUST_HOST=true

# ── Public site URL (used in emails + absolute links; no trailing slash) ─────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"   # prod: https://infinitysportspark.com

# ── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER="console"  # console | resend | ses
# Sender must be a verified identity on your verified domain (both providers):
EMAIL_FROM="Infinity Sports Park <no-reply@infinitysportspark.com>"
# Resend: key from https://resend.com after verifying the domain.
# RESEND_API_KEY=""
# Amazon SES: no API key — uses the AWS credentials/region below.

# ── SMS (optional; phone verification is optional for booking) ──────────────
SMS_PROVIDER="console"    # console | sns | twilio
# Amazon SNS: uses the AWS credentials/region below. `to` must be E.164.
# Twilio (not yet wired):
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# ── AWS (for SES email and/or SNS SMS) ──────────────────────────────────────
AWS_REGION="us-east-1"
# On AWS compute (Lightsail/EC2/App Runner) prefer an IAM role and OMIT these.
# Off AWS, use an IAM user with ses:SendRawEmail + sns:Publish only:
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# ── Google sign-in (optional; button shows only when both are set) ──────────
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ── Payments (optional) ─────────────────────────────────────────────────────
PAYMENTS_PROVIDER="mock"  # mock | stripe
# STRIPE_SECRET_KEY=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ── Legal ───────────────────────────────────────────────────────────────────
# While false, legal pages + signed waiver PDFs carry a DRAFT banner/watermark.
# Set true only after an attorney approves the live waiver text.
LEGAL_REVIEWED="false"
